<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>

<!--
  Productos View — Sistema de Inventario v2.0
  TableView tipado · Búsqueda en tiempo real · Sidebar UNISON
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mx.unison.inventario.vistas.ProductosControlador"
            stylesheets="@../css/inventario.css"
            prefWidth="1200" prefHeight="680">

    <!-- ── SIDEBAR ───────────────────────────────────────────────────── -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <VBox styleClass="sidebar-header" spacing="4">
                <Label text="📦 Inventario" styleClass="sidebar-logo-text"/>
                <Label text="SISTEMA UNISON v2.0" styleClass="sidebar-logo-sub"/>
            </VBox>
            <Region styleClass="sidebar-separator"/>
            <VBox spacing="4" style="-fx-padding: 16px 10px 10px 10px;">
                <Label text="NAVEGACIÓN" styleClass="sidebar-section-label"
                       style="-fx-padding: 0px 10px 6px 10px;"/>
                <Button text="🏠  Inicio" styleClass="btn-nav" onAction="#regresar"/>
                <Button text="📦  Productos" styleClass="btn-nav-active"/>
                <Button text="🏭  Almacenes" styleClass="btn-nav" onAction="#irAlmacenes"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox styleClass="sidebar-separator"/>
            <VBox styleClass="sidebar-user-panel" spacing="4">
                <Label fx:id="labelUsuario"
                       styleClass="sidebar-user-name"
                       text="Usuario"/>

                <Label fx:id="labelRol"
                       styleClass="sidebar-user-role"
                       text="Rol"/>

                <Region prefHeight="8"/>

                <Button text="⎋  Cerrar sesión"
                        styleClass="btn-nav-logout"
                        onAction="#cerrarSesion"/>
            </VBox>
        </VBox>
    </left>

    <!-- ── CONTENIDO ────────────────────────────────────────────────── -->
    <center>
        <VBox spacing="0">

            <!-- Topbar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
                <Label text="📦  Productos" styleClass="topbar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="labelConteo" styleClass="label-badge" text="0 producto(s)"/>
            </HBox>

            <!-- Área de contenido -->
            <VBox styleClass="content-area" spacing="20" VBox.vgrow="ALWAYS">

                <!-- Barra de acciones -->
                <HBox styleClass="action-bar" spacing="10" alignment="CENTER_LEFT">
                    <Button text="+ Agregar"  styleClass="btn-primary"   onAction="#agregar"/>
                    <Button text="✏ Editar"   styleClass="btn-secondary" onAction="#editar"/>
                    <Button text="🗑 Eliminar" styleClass="btn-danger"    onAction="#eliminar"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="campoBusqueda"
                               promptText="🔍  Buscar por nombre..."
                               styleClass="search-field"
                               prefWidth="260"/>
                </HBox>

                <!-- Tabla de productos -->
                <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">

                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="55"
                                     style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colNombre"      text="Nombre"      prefWidth="200"/>
                        <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="200"/>
                        <TableColumn fx:id="colCantidad"    text="Cantidad"    prefWidth="90"
                                     style="-fx-alignment: CENTER_RIGHT;"/>
                        <TableColumn fx:id="colPrecio"      text="Precio"      prefWidth="100"
                                     style="-fx-alignment: CENTER_RIGHT;"/>
                        <TableColumn fx:id="colAlmacen"     text="Almacén"     prefWidth="160"/>
                        <TableColumn fx:id="colCreado"      text="Creado"      prefWidth="160"/>
                        <TableColumn fx:id="colUsuario"     text="Último usuario" prefWidth="130"/>
                    </columns>

                    <placeholder>
                        <Label text="No hay productos registrados. Haz clic en '+ Agregar' para comenzar."
                               style="-fx-font-family: 'Segoe UI'; -fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
                    </placeholder>

                </TableView>

            </VBox>
        </VBox>
    </center>

</BorderPane>
